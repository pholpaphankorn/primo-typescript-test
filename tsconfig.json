{
  "compilerOptions": {
    "target": "ES6",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES6"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    
    /* FIXES START HERE */
    "isolatedModules": true,        // Resolves TS151002 warning
    "types": ["jest", "node"],      // Resolves "Cannot find name 'describe'"
    /* FIXES END HERE */

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*", 
    "test/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}